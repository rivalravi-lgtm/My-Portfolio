<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dr. Mehta's Clinic | Your Health, Our Priority</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet"/>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;color:#1e293b;background:#f8fafc}
    nav{background:#fff;padding:18px 60px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:999;box-shadow:0 2px 12px rgba(0,0,0,0.07)}
    nav .logo{color:#0ea5e9;font-size:22px;font-weight:700}
    nav .logo span{color:#1e293b}
    nav ul{list-style:none;display:flex;gap:30px}
    nav ul li a{color:#475569;text-decoration:none;font-size:14px;transition:color 0.3s}
    nav ul li a:hover{color:#0ea5e9}
    .btn{background:#0ea5e9;color:#fff;padding:12px 30px;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.3s}
    .btn:hover{background:#0284c7;transform:translateY(-2px)}
    .hero{background:linear-gradient(135deg,#e0f2fe 0%,#f0f9ff 100%);padding:100px 80px;display:flex;align-items:center;gap:60px;min-height:90vh}
    .hero .text{flex:1}
    .hero .text .badge{background:#dbeafe;color:#1d4ed8;padding:8px 20px;border-radius:40px;font-size:12px;font-weight:600;letter-spacing:1px;display:inline-block;margin-bottom:24px}
    .hero .text h1{font-size:54px;line-height:1.2;margin-bottom:20px;color:#0f172a}
    .hero .text h1 span{color:#0ea5e9}
    .hero .text p{font-size:16px;color:#64748b;line-height:1.8;max-width:480px;margin-bottom:32px}
    .hero .text .actions{display:flex;gap:16px;flex-wrap:wrap}
    .btn-outline{background:transparent;border:2px solid #0ea5e9;color:#0ea5e9}
    .btn-outline:hover{background:#0ea5e9;color:#fff}
    .hero .image{flex:1;text-align:right}
    .hero .image img{width:100%;max-width:440px;border-radius:20px;box-shadow:0 20px 60px rgba(14,165,233,0.2)}
    .trust-bar{background:#0ea5e9;padding:30px 80px;display:flex;justify-content:space-around;flex-wrap:wrap;gap:20px}
    .trust-item{text-align:center;color:#fff}
    .trust-item h3{font-size:32px;font-weight:700}
    .trust-item p{font-size:12px;opacity:0.85;letter-spacing:1px}
    .services{padding:90px 80px;text-align:center;background:#fff}
    .section-title{font-size:38px;font-weight:700;margin-bottom:10px;color:#0f172a}
    .section-sub{color:#94a3b8;font-size:14px;margin-bottom:50px}
    .service-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
    .service-card{background:#f8fafc;border-radius:16px;padding:36px 28px;text-align:left;border:1px solid #e2e8f0;transition:all 0.3s;cursor:pointer}
    .service-card:hover{border-color:#0ea5e9;background:#f0f9ff;transform:translateY(-4px)}
    .service-card .icon{font-size:38px;margin-bottom:16px}
    .service-card h3{font-size:17px;font-weight:600;margin-bottom:8px}
    .service-card p{font-size:13px;color:#64748b;line-height:1.7}
    .doctors{padding:90px 80px;text-align:center;background:#f8fafc}
    .doc-cards{display:flex;flex-wrap:wrap;gap:28px;justify-content:center;margin-top:50px}
    .doc-card{background:#fff;border-radius:16px;padding:30px;width:240px;box-shadow:0 4px 20px rgba(0,0,0,0.06);text-align:center}
    .doc-card img{width:120px;height:120px;border-radius:50%;object-fit:cover;margin-bottom:16px;border:3px solid #bae6fd}
    .doc-card h3{font-size:16px;font-weight:700;margin-bottom:4px}
    .doc-card .specialty{font-size:12px;color:#0ea5e9;font-weight:600;letter-spacing:0.5px}
    .doc-card .exp{font-size:12px;color:#94a3b8;margin-top:6px}
    .appointment{padding:90px 80px;text-align:center;background:#fff}
    .appointment form{max-width:580px;margin:40px auto 0;display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .appointment form input,.appointment form select{padding:14px 18px;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;font-family:'Inter',sans-serif;outline:none;background:#fff;transition:border 0.3s}
    .appointment form input:focus,.appointment form select:focus{border-color:#0ea5e9}
    .appointment form .full{grid-column:1/-1}
    footer{background:#0f172a;color:#475569;text-align:center;padding:28px;font-size:13px}
    footer span{color:#0ea5e9}
  </style>
</head>
<body>
  <nav>
    <div class="logo">🩺 Dr. Mehta's <span>Clinic</span></div>
    <ul>
      <li><a href="#services">Services</a></li>
      <li><a href="#doctors">Doctors</a></li>
      <li><a href="#appointment">Appointment</a></li>
    </ul>
    <a href="#appointment" class="btn">Book Now</a>
  </nav>

  <section class="hero">
    <div class="text">
      <span class="badge">✅ Trusted by 10,000+ Patients</span>
      <h1>Your Health is<br/>Our <span>Priority</span></h1>
      <p>Compassionate, expert medical care for your entire family. Book an appointment today and experience healthcare that truly cares.</p>
      <div class="actions">
        <a href="#appointment" class="btn">Book Appointment</a>
        <a href="#services" class="btn btn-outline">Our Services</a>
      </div>
    </div>
    <div class="image">
      <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=800" alt="doctor"/>
    </div>
  </section>

  <section class="trust-bar">
    <div class="trust-item"><h3>15+</h3><p>Years Experience</p></div>
    <div class="trust-item"><h3>10K+</h3><p>Happy Patients</p></div>
    <div class="trust-item"><h3>8</h3><p>Specialist Doctors</p></div>
    <div class="trust-item"><h3>4.9★</h3><p>Average Rating</p></div>
  </section>

  <section class="services" id="services">
    <h2 class="section-title">Our Medical Services</h2>
    <p class="section-sub">Comprehensive care under one roof</p>
    <div class="service-grid">
      <div class="service-card"><div class="icon">🫀</div><h3>Cardiology</h3><p>Heart health check-ups, ECG, stress tests and cardiac consultations.</p></div>
      <div class="service-card"><div class="icon">🧠</div><h3>Neurology</h3><p>Expert diagnosis and treatment for brain and nervous system disorders.</p></div>
      <div class="service-card"><div class="icon">🦴</div><h3>Orthopedics</h3><p>Bone, joint and muscle care — from sports injuries to arthritis management.</p></div>
      <div class="service-card"><div class="icon">👁️</div><h3>Ophthalmology</h3><p>Eye exams, vision correction, cataract and retina treatments.</p></div>
      <div class="service-card"><div class="icon">🩸</div><h3>Lab & Diagnostics</h3><p>Full blood panel, urine tests, X-ray, ultrasound and more — same day reports.</p></div>
      <div class="service-card"><div class="icon">👶</div><h3>Pediatrics</h3><p>Specialized care for newborns, infants, children and adolescents.</p></div>
    </div>
  </section>

  <section class="doctors" id="doctors">
    <h2 class="section-title">Our Doctors</h2>
    <p class="section-sub">Qualified. Experienced. Caring.</p>
    <div class="doc-cards">
      <div class="doc-card"><img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400" alt=""/><h3>Dr. Ramesh Mehta</h3><div class="specialty">Cardiologist</div><div class="exp">20 years experience</div></div>
      <div class="doc-card"><img src="https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400" alt=""/><h3>Dr. Priya Nair</h3><div class="specialty">Neurologist</div><div class="exp">14 years experience</div></div>
      <div class="doc-card"><img src="https://images.unsplash.com/photo-1537368910025-700350fe46c7?w=400" alt=""/><h3>Dr. Anil Sharma</h3><div class="specialty">Pediatrician</div><div class="exp">12 years experience</div></div>
    </div>
  </section>

  <section class="appointment" id="appointment">
    <h2 class="section-title">Book an Appointment</h2>
    <p class="section-sub">Quick and easy — takes less than 60 seconds</p>
    <form>
      <input type="text" placeholder="Patient Name" class="full"/>
      <input type="tel" placeholder="Phone Number"/>
      <input type="email" placeholder="Email Address"/>
      <select><option>Select Department</option><option>Cardiology</option><option>Neurology</option><option>Orthopedics</option><option>Ophthalmology</option><option>Pediatrics</option><option>General</option></select>
      <input type="date" placeholder="Preferred Date"/>
      <select class="full"><option>Preferred Time Slot</option><option>9:00 AM - 11:00 AM</option><option>11:00 AM - 1:00 PM</option><option>2:00 PM - 5:00 PM</option><option>6:00 PM - 8:00 PM</option></select>
      <button type="submit" class="btn full">Confirm Appointment</button>
    </form>
  </section>

  <footer>
    <p>© 2025 <span>Dr. Mehta's Clinic</span> · Your Health, Our Priority · All Rights Reserved</p>
  </footer>
</body>
</html>
