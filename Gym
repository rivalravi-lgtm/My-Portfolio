<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>IronPeak Gym | Unleash Your Strength</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet"/>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Poppins',sans-serif;background:#0d0d0d;color:#fff}
    nav{background:#0d0d0d;padding:18px 60px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:999;border-bottom:1px solid #1f1f1f}
    nav .logo{color:#e63946;font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:3px}
    nav ul{list-style:none;display:flex;gap:30px}
    nav ul li a{color:#ccc;text-decoration:none;font-size:13px;letter-spacing:1px;text-transform:uppercase;transition:color 0.3s}
    nav ul li a:hover{color:#e63946}
    .hero{background:linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1600') center/cover;height:100vh;display:flex;align-items:center;padding:0 80px}
    .hero h1{font-family:'Bebas Neue',sans-serif;font-size:90px;line-height:1;color:#fff}
    .hero h1 span{color:#e63946}
    .hero p{font-size:16px;color:#bbb;max-width:450px;margin:20px 0 35px;line-height:1.8}
    .btn{background:#e63946;color:#fff;padding:14px 40px;border:none;border-radius:4px;font-size:14px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.3s}
    .btn:hover{background:#c1121f;transform:translateY(-2px)}
    .btn-outline{background:transparent;border:2px solid #e63946;color:#e63946;margin-left:16px}
    .btn-outline:hover{background:#e63946;color:#fff}
    .stats{background:#e63946;padding:40px 80px;display:flex;justify-content:space-around;flex-wrap:wrap;gap:20px}
    .stat{text-align:center}
    .stat h2{font-family:'Bebas Neue',sans-serif;font-size:48px}
    .stat p{font-size:12px;letter-spacing:2px;text-transform:uppercase;opacity:0.85}
    .programs{padding:90px 80px;text-align:center}
    .section-title{font-family:'Bebas Neue',sans-serif;font-size:50px;letter-spacing:3px}
    .section-sub{color:#777;font-size:14px;margin-bottom:55px;letter-spacing:1px}
    .prog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
    .prog-card{position:relative;height:260px;border-radius:10px;overflow:hidden;cursor:pointer}
    .prog-card img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s}
    .prog-card:hover img{transform:scale(1.08)}
    .prog-card .overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85),transparent);display:flex;align-items:flex-end;padding:24px}
    .prog-card .overlay h3{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:2px}
    .membership{padding:90px 80px;background:#111;text-align:center}
    .mem-cards{display:flex;flex-wrap:wrap;gap:24px;justify-content:center;margin-top:50px}
    .mem-card{border:1px solid #2a2a2a;border-radius:12px;padding:40px 30px;width:250px;transition:all 0.3s}
    .mem-card:hover,.mem-card.best{border-color:#e63946;background:#1a0a0a}
    .mem-card h3{font-size:18px;font-weight:700;letter-spacing:1px;margin-bottom:10px}
    .mem-card .price{font-family:'Bebas Neue',sans-serif;font-size:52px;color:#e63946}
    .mem-card .price span{font-size:16px;color:#777;font-family:'Poppins',sans-serif}
    .mem-card ul{list-style:none;margin:20px 0;text-align:left}
    .mem-card ul li{font-size:13px;padding:7px 0;border-bottom:1px solid #2a2a2a;color:#ccc}
    .mem-card ul li::before{content:"→ ";color:#e63946}
    .trainers{padding:90px 80px;text-align:center}
    .trainer-cards{display:flex;flex-wrap:wrap;gap:30px;justify-content:center;margin-top:50px}
    .trainer-card{width:220px;text-align:center}
    .trainer-card img{width:180px;height:180px;border-radius:50%;object-fit:cover;border:4px solid #e63946;margin-bottom:16px}
    .trainer-card h3{font-size:16px;font-weight:700}
    .trainer-card p{font-size:12px;color:#777;letter-spacing:1px;text-transform:uppercase}
    .contact{padding:90px 80px;background:#111;text-align:center}
    .contact form{max-width:520px;margin:40px auto 0;display:flex;flex-direction:column;gap:14px}
    .contact form input,.contact form select,.contact form textarea{background:#1a1a1a;border:1px solid #2a2a2a;color:#fff;padding:14px 18px;border-radius:6px;font-size:14px;font-family:'Poppins',sans-serif;outline:none;transition:border 0.3s}
    .contact form input:focus,.contact form select:focus,.contact form textarea:focus{border-color:#e63946}
    .contact form select option{background:#1a1a1a}
    .contact form textarea{height:110px;resize:none}
    footer{background:#0d0d0d;border-top:1px solid #1f1f1f;text-align:center;padding:24px;color:#555;font-size:12px;letter-spacing:1px}
    footer span{color:#e63946}
  </style>
</head>
<body>
  <nav>
    <div class="logo">⚡ IronPeak</div>
    <ul>
      <li><a href="#programs">Programs</a></li>
      <li><a href="#membership">Membership</a></li>
      <li><a href="#trainers">Trainers</a></li>
      <li><a href="#contact">Join Now</a></li>
    </ul>
  </nav>

  <section class="hero">
    <div>
      <h1>BREAK<br/><span>YOUR</span><br/>LIMITS</h1>
      <p>State-of-the-art equipment, expert trainers, and a community that pushes you further every single day.</p>
      <a href="#contact" class="btn">Start Free Trial</a>
      <a href="#membership" class="btn btn-outline">View Plans</a>
    </div>
  </section>

  <section class="stats">
    <div class="stat"><h2>5000+</h2><p>Active Members</p></div>
    <div class="stat"><h2>20+</h2><p>Expert Trainers</p></div>
    <div class="stat"><h2>15+</h2><p>Programs</p></div>
    <div class="stat"><h2>8 Yrs</h2><p>Experience</p></div>
  </section>

  <section class="programs" id="programs">
    <h2 class="section-title">Training Programs</h2>
    <p class="section-sub">Find your perfect workout</p>
    <div class="prog-grid">
      <div class="prog-card"><img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600" alt=""/><div class="overlay"><h3>Weight Training</h3></div></div>
      <div class="prog-card"><img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=600" alt=""/><div class="overlay"><h3>Cardio Blast</h3></div></div>
      <div class="prog-card"><img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600" alt=""/><div class="overlay"><h3>Yoga & Flexibility</h3></div></div>
      <div class="prog-card"><img src="https://images.unsplash.com/photo-1549060279-7e168fcee0c2?w=600" alt=""/><div class="overlay"><h3>CrossFit</h3></div></div>
      <div class="prog-card"><img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600" alt=""/><div class="overlay"><h3>Boxing</h3></div></div>
      <div class="prog-card"><img src="https://images.unsplash.com/photo-1606902965551-dce093cda6e7?w=600" alt=""/><div class="overlay"><h3>Zumba & Dance</h3></div></div>
    </div>
  </section>

  <section class="membership" id="membership">
    <h2 class="section-title">Membership Plans</h2>
    <p class="section-sub">No contracts. Cancel anytime.</p>
    <div class="mem-cards">
      <div class="mem-card">
        <h3>STARTER</h3>
        <div class="price">₹799<span>/mo</span></div>
        <ul><li>Gym Access</li><li>Locker Room</li><li>2 Group Classes</li></ul>
        <a href="#contact" class="btn">Get Started</a>
      </div>
      <div class="mem-card best">
        <h3>🔥 PRO</h3>
        <div class="price">₹1499<span>/mo</span></div>
        <ul><li>Unlimited Access</li><li>Personal Trainer</li><li>All Classes</li><li>Diet Plan</li></ul>
        <a href="#contact" class="btn">Get Started</a>
      </div>
      <div class="mem-card">
        <h3>ELITE</h3>
        <div class="price">₹2499<span>/mo</span></div>
        <ul><li>Everything in Pro</li><li>Sauna & Spa</li><li>Monthly Assessment</li><li>Priority Booking</li></ul>
        <a href="#contact" class="btn">Get Started</a>
      </div>
    </div>
  </section>

  <section class="trainers" id="trainers">
    <h2 class="section-title">Meet Our Trainers</h2>
    <p class="section-sub">Certified. Experienced. Passionate.</p>
    <div class="trainer-cards">
      <div class="trainer-card"><img src="https://images.unsplash.com/photo-1534308143481-c55f00be8bd7?w=400" alt=""/><h3>Arjun Kapoor</h3><p>Strength & Conditioning</p></div>
      <div class="trainer-card"><img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=400" alt=""/><h3>Neha Rawat</h3><p>Yoga & Wellness</p></div>
      <div class="trainer-card"><img src="https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=400" alt=""/><h3>Vikram Sinha</h3><p>CrossFit & Boxing</p></div>
    </div>
  </section>

  <section class="contact" id="contact">
    <h2 class="section-title">Start Your Journey</h2>
    <p class="section-sub">Book your free trial today</p>
    <form>
      <input type="text" placeholder="Full Name"/>
      <input type="email" placeholder="Email Address"/>
      <input type="tel" placeholder="Phone Number"/>
      <select><option>Select Program</option><option>Weight Training</option><option>Cardio</option><option>Yoga</option><option>CrossFit</option><option>Boxing</option><option>Zumba</option></select>
      <textarea placeholder="Any questions or goals you'd like to share?"></textarea>
      <button type="submit" class="btn">CLAIM FREE TRIAL</button>
    </form>
  </section>

  <footer>
    <p>© 2025 <span>IRONPEAK GYM</span> · ALL RIGHTS RESERVED · BUILT WITH 💪</p>
  </footer>
</body>
</html>
